# === Core ignore rules for AI_mind_rep ===

# Claude Code local config
.claude/

# Data and logs
**/data/
**/logs/

# Archived old code/results (preserved locally, not tracked)
**/archive/

# Python caches and compiled files
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Environments
.env
.venv/
venv/
env/

# OS and editor files
.DS_Store
.nfs*
Thumbs.db
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/

# Temporary files
*.tmp
*.bak
*.log

# Exp 5 analysis code (kept locally, not tracked)
exp_5/code/rsa/
exp_5/code/probes/
exp_5/code/interchange/
exp_5/approach_brainstorm.md

# Large model or activation files
**/activations/
**/embeddings/
**/checkpoints/
**/tmp/
*.npz
